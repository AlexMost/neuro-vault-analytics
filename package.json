{
  "name": "neuro-vault-analytics",
  "version": "0.1.0",
  "description": "Claude Code plugin + CLI for analyzing Claudian conversation records to surface usage patterns, gaps, and actionable suggestions for neuro-vault.",
  "homepage": "https://github.com/AlexMost/neuro-vault-analytics#readme",
  "bugs": {
    "url": "https://github.com/AlexMost/neuro-vault-analytics/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexMost/neuro-vault-analytics.git"
  },
  "license": "ISC",
  "keywords": [
    "claude-code",
    "plugin",
    "obsidian",
    "claudian",
    "analytics",
    "neuro-vault"
  ],
  "author": "",
  "type": "module",
  "bin": {
    "nv-analytics": "./dist/cli.js"
  },
  "files": [
    "dist",
    ".claude-plugin",
    "skills",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "format:changelog": "prettier --write CHANGELOG.md",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prerelease": "npm run build && npm run test && npm run lint && npm run format",
    "release": "commit-and-tag-version",
    "release:dry-run": "commit-and-tag-version --dry-run",
    "prepublishOnly": "npm run build && npm run test && npm run lint && npm run format"
  },
  "dependencies": {
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.15.18",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "commit-and-tag-version": "^12.6.1",
    "eslint": "^9.25.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "commit-and-tag-version": {
    "tagPrefix": "v",
    "releaseCommitMessageFormat": "chore(release): {{currentTag}}",
    "scripts": {
      "postchangelog": "npm run format:changelog"
    }
  },
  "packageManager": "npm@10.9.2"
}
